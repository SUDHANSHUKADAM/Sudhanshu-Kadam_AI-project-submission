# =============================================================================
# .env.example
# Only required if you use the OPTIONAL LLM sentiment labeler in
# src/sentiment_llm.py. The default VADER labeler (src/sentiment.py) needs NONE
# of these. Copy this file to `.env` and fill in your provider's key.
# =============================================================================

# Which provider to use: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# --- Anthropic ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
